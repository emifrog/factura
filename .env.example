# =============================================================================
# Factura — variables d'environnement
# Copie ce fichier en `.env.local` et renseigne les valeurs réelles.
# Ne JAMAIS commiter `.env.local` ni de clés réelles.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (DB + Auth + Storage)
# Région obligatoire : eu-central-1 (Frankfurt) — RGPD.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Côté serveur uniquement (Server Actions, Route Handlers). Jamais exposée au client.
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Stripe Billing (abonnements Pro / Pro+)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# IDs des prix Stripe correspondant aux plans (créés dans le dashboard Stripe)
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_PRO_PLUS_MONTHLY=
STRIPE_PRICE_PRO_PLUS_YEARLY=

# -----------------------------------------------------------------------------
# Sentry (monitoring)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# -----------------------------------------------------------------------------
# Email transactionnel (TBD : Resend ou Postmark)
# -----------------------------------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM="Factura <hello@factura.fr>"

# -----------------------------------------------------------------------------
# API SIRENE INSEE (gratuit, vérification SIREN entreprise/clients B2B)
# https://api.insee.fr/catalogue/
# -----------------------------------------------------------------------------
INSEE_API_KEY=

# -----------------------------------------------------------------------------
# PDP partenaire (à définir Phase 0 — variables provisoires)
# Le format dépendra du contrat. Préparer une couche d'abstraction PdpProvider.
# -----------------------------------------------------------------------------
PDP_PROVIDER=mock
PDP_API_URL=
PDP_API_KEY=
PDP_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
